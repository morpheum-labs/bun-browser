FROM oven/bun:1-debian

# Install Chrome + Xvfb + noVNC + Nginx (for auth)
RUN apt-get update && apt-get install -y \
    google-chrome-stable \
    xvfb \
    tightvncserver \
    novnc \
    websockify \
    nginx \
    apache2-utils \
    fonts-liberation \
    libnss3 libatk-bridge2.0-0 libdrm2 libxkbcommon0 \
    libxcomposite1 libxdamage1 libxrandr2 libgbm1 libasound2 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install bun-browser globally
RUN bun add -g bun-browser

# Copy the unpacked extension and entrypoint
COPY ./extension /app/extension
COPY ./entrance.sh /app/entrance.sh

# Persistent Chrome profile (your real session holder)
VOLUME /chrome-profile

# Default credentials (CHANGE THESE!)
ENV VNC_USERNAME=admin
ENV VNC_PASSWORD=change_this_to_a_strong_password_please

EXPOSE 19824 9222 6080

# Start everything with authentication
CMD ["bash", "/app/entrance.sh"]