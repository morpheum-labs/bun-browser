FROM oven/bun:1-debian

# google-chrome-stable is not in default Debian repos; Google only publishes amd64 for Linux.
# Install Chrome (amd64) or Chromium (other arches) + Xvfb + noVNC + Nginx (for auth)
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates gnupg wget \
    && set -eux; \
    ARCH="$(dpkg --print-architecture)"; \
    if [ "${ARCH}" = "amd64" ]; then \
      wget -q -O - https://dl.google.com/linux/linux_signing_key.pub \
        | gpg --dearmor -o /usr/share/keyrings/google-chrome.gpg; \
      echo "deb [arch=amd64 signed-by=/usr/share/keyrings/google-chrome.gpg] http://dl.google.com/linux/chrome/deb/ stable main" \
        > /etc/apt/sources.list.d/google-chrome.list; \
      apt-get update; \
      apt-get install -y --no-install-recommends google-chrome-stable; \
    else \
      apt-get install -y --no-install-recommends chromium; \
      ln -sf /usr/bin/chromium /usr/local/bin/google-chrome; \
    fi \
    && apt-get install -y --no-install-recommends \
    xvfb \
    tightvncserver \
    novnc \
    websockify \
    nginx \
    apache2-utils \
    fonts-liberation \
    libnss3 libatk-bridge2.0-0 libdrm2 libxkbcommon0 \
    libxcomposite1 libxdamage1 libxrandr2 libgbm1 libasound2 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# bun-browser is not published to npm; build from this repo and expose CLI on PATH
COPY package.json bun.lock ./
COPY turbo.json tsconfig.base.json tsup.config.ts ./
COPY packages ./packages
RUN bun install --frozen-lockfile \
    && bun run build \
    && printf '%s\n' '#!/bin/sh' 'exec bun /app/dist/cli.js "$@"' > /usr/local/bin/bun-browser \
    && printf '%s\n' '#!/bin/sh' 'exec bun /app/dist/mcp.js "$@"' > /usr/local/bin/bun-browser-mcp \
    && chmod +x /usr/local/bin/bun-browser /usr/local/bin/bun-browser-mcp

COPY ./entrance.sh /app/entrance.sh

# Persistent Chrome profile (your real session holder)
VOLUME /chrome-profile

# VNC_USERNAME / VNC_PASSWORD: set at runtime (e.g. compose.yml environment), not in the image

EXPOSE 19824 9222 6080

# Start everything with authentication
CMD ["bash", "/app/entrance.sh"]