{
  "name": "bun-browser",
  "version": "0.10.2",
  "description": "Your browser is the API. CLI + MCP server for AI agents to control Chrome with your login state.",
  "type": "module",
  "bin": {
    "bun-browser": "./dist/cli.js",
    "bun-browser-mcp": "./dist/mcp.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "extension",
    "README.md",
    "LICENSE"
  ],
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun node_modules/turbo/bin/turbo run build && bun run build:release",
    "build:release": "bunx --bun tsup && bun run build:extension",
    "build:extension": "rm -rf extension && cp -r packages/extension/dist extension",
    "dev": "bun node_modules/turbo/bin/turbo run dev",
    "test": "bun node_modules/turbo/bin/turbo run test",
    "lint": "bun node_modules/turbo/bin/turbo run lint",
    "clean": "bun node_modules/turbo/bin/turbo run clean && rm -rf node_modules dist extension",
    "prepublishOnly": "bun run build:release"
  },
  "keywords": [
    "browser",
    "automation",
    "ai",
    "agent",
    "chrome",
    "extension",
    "cli",
    "puppeteer",
    "playwright",
    "cdp",
    "mcp"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/morpheum-labs/bun-browser.git"
  },
  "bugs": {
    "url": "https://github.com/morpheum-labs/bun-browser/issues"
  },
  "homepage": "https://github.com/morpheum-labs/bun-browser#readme",
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.1.0"
  },
  "packageManager": "bun@1.3.10",
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-node": "^2.1.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "eslint": "^9.23.0",
    "globals": "^16.0.0",
    "tsup": "^8.0.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.29.0"
  }
}